{
  "name": "Friend",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "User who sent/accepted the friend request"
    },
    "friend_id": {
      "type": "string",
      "description": "The friend user ID"
    },
    "friend_name": {
      "type": "string",
      "description": "Friend's display name \u2014 kept as a lightweight fallback only. Source of truth is UserProfile."
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "accepted"
      ],
      "default": "pending",
      "description": "Friendship status"
    }
  },
  "required": [
    "user_id",
    "friend_id"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "data.user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "data.user_id": "{{user.id}}"
        },
        {
          "data.friend_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.user_id": "{{user.id}}"
        },
        {
          "data.friend_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "data.user_id": "{{user.id}}"
        },
        {
          "data.friend_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}